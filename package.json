{
  "name": "saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first next dev",
    "build": "prisma generate && cross-env NODE_OPTIONS=--dns-result-order=ipv4first next build",
    "start": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first prisma db push",
    "db:migrate": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first prisma migrate dev",
    "db:seed": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "6.19.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
